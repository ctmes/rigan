---
import BaseLayout from "@/layouts/Base.astro";
import { demos, type Demo } from "@/data/demos";

export function getStaticPaths() {
  return demos.map((d) => ({
    params: { slug: d.slug },
    props: { demo: d },
  }));
}

interface Props { demo: Demo }
const { demo } = Astro.props;
---

<BaseLayout title={demo.title} description={demo.tagline}>
  <div class="max-w-5xl mx-auto px-6 py-20">

    <!-- Page header matching about layout -->
    <div class="max-w-2xl">
      <span class="font-mono text-[10px] uppercase tracking-[0.15em] text-dim block mb-5">
        Live demo
      </span>
      <h1
        class="text-title font-semibold mb-4"
        style={{
          backgroundImage: "linear-gradient(100deg, #0a0a0a 0%, #191970 50%, #2c3580 100%)",
          WebkitBackgroundClip: "text",
          WebkitTextFillColor: "transparent",
          backgroundClip: "text",
        }}
      >
        {demo.title}
      </h1>
      <div class="mt-1 mb-4 h-[3px] w-12 rounded-full" style="background: linear-gradient(to right, #191970, #2c3580)" />
      <p class="text-dim leading-relaxed">{demo.description}</p>
    </div>

    <!-- Meta row -->
    <div class="mt-20 border-t border-rule pt-16 grid md:grid-cols-5 gap-16">
      <div class="md:col-span-2 space-y-6">
        <div>
          <span class="font-mono text-[10px] uppercase tracking-[0.15em] text-dim block mb-3">Stack</span>
          <div class="flex gap-2 flex-wrap">
            {demo.stack.map((s) => (
              <span class="font-mono text-[10px] uppercase tracking-[0.12em] text-dim bg-surface border border-rule px-2 py-1 rounded">
                {s}
              </span>
            ))}
          </div>
        </div>
        <div class="flex flex-col gap-3">
          {demo.github && (
            <a
              href={demo.github}
              target="_blank"
              rel="noopener noreferrer"
              class="text-sm text-dim hover:text-ink transition-colors"
            >
              View on GitHub ↗
            </a>
          )}
          <a
            href={demo.url}
            target="_blank"
            rel="noopener noreferrer"
            class="text-sm text-dim hover:text-ink transition-colors"
          >
            Open in new tab ↗
          </a>
        </div>
      </div>
    </div>

  </div>

  <!-- Full-width iframe below the contained content -->
  <div class="border-t border-rule" style="height: calc(100vh - 80px); min-height: 520px;">
    <iframe
      src={demo.url}
      title={demo.title}
      class="w-full h-full border-0"
      allow="fullscreen; clipboard-write"
      loading="lazy"
    />
  </div>

</BaseLayout>
