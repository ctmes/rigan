---
import BaseLayout from "@/layouts/Base.astro";
import PageHeader from "@/components/PageHeader";
import CTA from "@/components/CTA";

const experience = [
  {
    period: "2019 – present",
    role: "Founder & Principal Engineer",
    context: "Rigan Software Studio",
    detail:
      "Independent consulting practice focused on architecture-first software delivery for FinTech, quant, and B2B SaaS clients across Australia and the UK.",
  },
  {
    period: "2016 – 2019",
    role: "Senior Software Engineer",
    context: "Investment banking, London",
    detail:
      "Built real-time risk and pricing systems for a tier-1 bank's equity derivatives desk. Primary stack: Python, C++, kdb+/q.",
  },
  {
    period: "2013 – 2016",
    role: "Software Engineer",
    context: "Early-stage SaaS, Perth",
    detail:
      "Full-stack engineering on a B2B workflow platform from seed to Series A. First engineering hire.",
  },
];

const capabilities = [
  "Systems architecture & design",
  "TypeScript / Node.js / Python",
  "PostgreSQL, Redis, event-driven pipelines",
  "React, Astro",
  "AWS, Fly.io, infrastructure-as-code",
  "Quantitative modelling & backtesting",
  "kdb+/q, DuckDB, data warehouse design",
  "Technical due diligence",
];
---

<BaseLayout title="About" description="The team and practice behind Rigan Software Studio.">
  <div class="max-w-5xl mx-auto px-6 py-20">

    <PageHeader
      client:load
      label="About"
      heading="One studio. Small team."
      body="A tight-knit engineering team. No account managers, no juniors billed as seniors — you work directly with engineers who own the outcome."
    />

    <!-- Bio -->
    <div class="mt-20 grid md:grid-cols-5 gap-16 border-t border-rule pt-16">
      <div class="md:col-span-2">
        <span class="font-mono text-[10px] uppercase tracking-[0.15em] text-dim block mb-3">Background</span>
      </div>
      <div class="md:col-span-3 space-y-5 text-sm text-dim leading-relaxed">
        <p>
          We're a small team with a background in financial systems and early-stage product
          development. We spent years building real-time risk and pricing infrastructure for
          investment banks and high-growth startups before coming together to work independently.
        </p>
        <p>
          We started Rigan because we kept seeing the same pattern: technically capable teams
          blocked by poor architecture decisions made early, or founders burned by agencies who
          built for the invoice rather than the outcome. We work with a small number of clients
          at a time so we can actually care about the result.
        </p>
        <p>
          Our strongest domain is data-intensive systems — pipelines, analytics, real-time
          processing — but we take on broader full-stack and platform work when the problem
          is interesting enough.
        </p>
      </div>
    </div>

    <!-- Experience -->
    <div class="mt-16 border-t border-rule pt-16">
      <span class="font-mono text-[10px] uppercase tracking-[0.15em] text-dim block mb-10">Founding background</span>
      <div class="divide-y divide-rule">
        {experience.map((e) => (
          <div class="py-8 grid md:grid-cols-5 gap-8 md:gap-16">
            <div class="md:col-span-2">
              <span class="font-mono text-[10px] text-dim block mb-1">{e.period}</span>
              <span class="text-sm font-medium text-ink block">{e.role}</span>
              <span class="text-sm text-dim">{e.context}</span>
            </div>
            <div class="md:col-span-3">
              <p class="text-sm text-dim leading-relaxed">{e.detail}</p>
            </div>
          </div>
        ))}
      </div>
    </div>

    <!-- Capabilities -->
    <div class="mt-16 border-t border-rule pt-16 grid md:grid-cols-5 gap-16">
      <div class="md:col-span-2">
        <span class="font-mono text-[10px] uppercase tracking-[0.15em] text-dim block mb-3">Capabilities</span>
      </div>
      <div class="md:col-span-3">
        <ul class="grid sm:grid-cols-2 gap-x-8 gap-y-3">
          {capabilities.map((c) => (
            <li class="flex items-baseline gap-3 text-sm text-ink">
              <span class="w-3 h-px bg-rule flex-shrink-0 mt-2" />
              {c}
            </li>
          ))}
        </ul>
      </div>
    </div>

  </div>

  <CTA
    client:visible
    heading="Want to work together?"
    body="We take on 2–3 engagements at a time. Reach out early."
    label="Start a conversation"
    href="/contact"
  />
</BaseLayout>
